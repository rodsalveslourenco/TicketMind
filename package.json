{
  "name": "ticketmind",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 5180 --strictPort",
    "dev:server": "node --watch --watch-preserve-output server/index.js",
    "build": "vite build",
    "test:notifications": "node --test tests/notifications.test.mjs",
    "smoke:release": "node scripts/release-smoke.mjs",
    "validate": "npm run build && npm run smoke:release",
    "deploy:render": "node scripts/render-deploy.mjs",
    "preview": "vite preview --host 0.0.0.0 --port 4180",
    "start": "node server/index.js"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.2.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.21"
  }
}
